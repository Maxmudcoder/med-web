# --- Lokallab: odatda bo‘sh qoldiring — Vite `/api` va `/uploads` ni 127.0.0.1:4000 ga proksilaydi.
# VITE_API_URL=http://127.0.0.1:4000

# --- Production (Vercel, boshqa statik hosting): API alohida domen bo‘lsa, build vaqtida majburiy.
# Vercel: Settings → Environment Variables
#   KEY:   VITE_API_URL
#   VALUE: https://api.med-iqtidor.uz
# (oxirida / qo‘ymang; kod `/api/...` ni o‘zi qo‘shadi)

# Canonical va Open Graph uchun to‘liq sayt asosiy manzili (oxiridagi / yozilmasin)
# VITE_SITE_URL=https://med-iqtidro.uz
